BRING_MAIL=deine@email.de
BRING_PASSWORD=deinPasswort
PORT=3000
# Für die KI-Rezeptanalyse (OpenRouter). Schlüssel anlegen unter https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# Optional: Modell überschreiben (Standard: openai/gpt-4o-mini)
OPENROUTER_MODEL=openai/gpt-4o-mini
# Passwortschutz (bei öffentlichem Zugriff ZWINGEND setzen). Leer = kein Schutz.
APP_PASSWORD=
# Optional: eigener Schlüssel zum Signieren der Sessions (sonst aus dem Passwort abgeleitet)
APP_SECRET=
